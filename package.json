{
  "name": "getpatter-mcp",
  "version": "0.4.0",
  "description": "MCP server for Patter Voice AI — give Claude (and any MCP client) the ability to make and receive phone calls",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "getpatter-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup && chmod +x dist/index.js",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build && npm test"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.109",
    "better-sqlite3": "^12.9.0",
    "cloudflared": "^0.7.1",
    "e2b": "^2.19.0",
    "getpatter": "^0.6.3",
    "libphonenumber-js": "^1.12.41",
    "mcp-use": "^1.24.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@vitest/coverage-v8": "^4.1.4",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "license": "MIT",
  "author": {
    "name": "PatterAI",
    "email": "hello@getpatter.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/PatterAI/patter-mcp.git"
  },
  "homepage": "https://github.com/PatterAI/patter-mcp#readme",
  "bugs": {
    "url": "https://github.com/PatterAI/patter-mcp/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "voice",
    "voice-ai",
    "phone",
    "telephony",
    "claude",
    "anthropic",
    "patter",
    "getpatter",
    "twilio",
    "telnyx",
    "openai",
    "elevenlabs"
  ]
}
