# === Required ===
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
OPENAI_API_KEY=sk-...

# === Pipeline mode (required for voice tools during calls) ===
DEEPGRAM_API_KEY=your-deepgram-key
ELEVENLABS_API_KEY=your-elevenlabs-key

# === Server ports ===
# MCP_PORT=3000
# PATTER_PORT=8000

# === Lifecycle ===
# By default the Patter HTTP server + cloudflared tunnel boot lazily on the
# first tool call. Set to "1" to boot eagerly at MCP startup (legacy ≤0.2.x).
# PATTER_EAGER=1

# Named cloudflared tunnel hostname for a stable webhook URL across restarts.
# Requires `cloudflared tunnel create` and a DNS CNAME pointing at the tunnel.
# PATTER_TUNNEL_HOSTNAME=patter.your-domain.com

# Public webhook URL when running behind your own ingress (no cloudflared).
# Defaults to "localhost" (quick tunnel) when unset.
# WEBHOOK_URL=https://your-domain.com/webhook

# === Agent defaults ===
# AGENT_SYSTEM_PROMPT=You are a helpful AI assistant accessible by phone.
# AGENT_FIRST_MESSAGE=Hello! I'm your AI assistant. How can I help?
# AGENT_VOICE=nova

# === E2B sandboxed execution (optional) ===
# When set, claude_code voice tool runs inside an isolated E2B sandbox per call.
# When absent, Claude Code runs locally via the Agent SDK.
# Get a key at https://e2b.dev
# E2B_API_KEY=e2b_...

# === Auth0 OAuth (optional) ===
# When set, all /mcp endpoints require a valid Bearer token.
# When absent, the server runs unauthenticated (local dev mode).
# AUTH0_DOMAIN=your-tenant.auth0.com
# AUTH0_AUDIENCE=https://your-api-identifier.example.com

# === SQLite persistence (optional) ===
# Path to the SQLite database file. Defaults to patter-mcp.db in the cwd.
# PATTER_DB_PATH=patter-mcp.db

# === Rate limiting & safety (optional) ===
# Max outbound calls per authenticated user per calendar day (UTC). Default: 10.
# RATE_LIMIT_DAILY=10
# Max simultaneous active calls per user. Default: 2.
# MAX_CONCURRENT_CALLS=2
# Max call duration in seconds before the call is force-terminated. Default: 300 (5 min).
# MAX_CALL_DURATION_SECONDS=300
# Global hourly spend cap in USD. When set, new calls are blocked once the cap is reached.
# Calculated from the `cost.total` field in call metrics. Leave unset to disable.
# HOURLY_BUDGET_CAP_USD=5.00
